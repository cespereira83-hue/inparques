name: sistema_gestion_guardias
description: "Sistema de administración operativa, planificación de guardias y gestión legal."
publish_to: 'none'
version: 0.1.0

environment:
  sdk: '>=3.0.0 <4.0.0'

dependencies:
  flutter:
    sdk: flutter
  cupertino_icons: ^1.0.2

  # --- BASE DE DATOS (Drift / SQLite) ---
  drift: ^2.14.1
  sqlite3_flutter_libs: ^0.5.18
  path_provider: ^2.1.2
  path: ^1.8.3
  sqlite3: ^2.1.0

  # --- GENERACIÓN DE REPORTES Y ARCHIVOS ---
  # Se actualiza file_picker para compatibilidad con Android moderno (v3 embedding)
  pdf: ^3.10.7
  printing: ^5.11.1
  file_picker: ^8.1.2

  # --- LÓGICA Y UTILIDADES ---
  intl: ^0.19.0
  provider: ^6.1.1

dev_dependencies:
  flutter_test:
    sdk: flutter
  flutter_lints: ^3.0.0

  # --- GENERADORES DE CÓDIGO ---
  drift_dev: ^2.14.1
  build_runner: ^2.4.8

flutter:
  uses-material-design: true

  # Configuración de recursos para el sistema offline
  assets:
    - assets/database/
    - assets/images/